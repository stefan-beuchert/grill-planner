# These are PRODUCTION values only (set as Vercel project env vars).
# Local dev doesn't use this file — docker-compose.yml points the app at
# the local `db` container instead. Find both strings under Supabase's
# Project Settings -> Database -> Connection string.

# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
# Serverless functions open/close connections constantly; the pooler keeps
# Supabase's free-tier connection limit from being exhausted.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used only by Prisma Migrate/CLI. Schema
# migrations need session-level Postgres features (advisory locks) that
# don't work reliably through the transaction pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
