// Prisma schema for Grill Planner.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ItemListType {
  SHARED_PURCHASE
  BRING_YOUR_OWN
}

enum ItemCategory {
  FOOD
  DRINK
  OTHER
}

/// A single grill party. `slug` is the unguessable public id used in the
/// shareable URL — it is the only "authorization" a visitor needs.
model Party {
  id        String   @id @default(cuid())
  slug      String   @unique
  /// Held only by the creator's browser (localStorage), never a cookie —
  /// same trust model as Participant.editToken. Lets whoever created a
  /// party manage it (edit details, cancel, unmark purchases, remove
  /// guests/contributions) without needing the app-wide admin passcode.
  /// A global admin can always do the same for every party regardless.
  organizerToken String @unique @default(cuid())
  title     String
  startsAt  DateTime
  location  String
  /// General note shown on the Guests tab. Independent from `locationNote`
  /// below — the two are separate coordination contexts even though they
  /// share the same lightweight note-widget UI.
  notes     String?
  /// Location/logistics-specific note shown on the Location tab (e.g.
  /// "parking is on the street, ring the doorbell twice"). Independent
  /// from `notes` above.
  locationNote String?
  /// Optional freeform note shown on the merged Shopping List tab (v4:
  /// Shared Purchases and Shopping List are one screen again) — e.g.
  /// "everyone grills their own meat, just chip in for extras".
  note      String?
  /// Optional freeform note shown on Things People Bring — a separate note
  /// from `note` above since it's a different coordination context (e.g.
  /// "please bring your own plates/cups").
  bringNote String?

  /// Cached AI Event Summary (see PRODUCT.md). Regenerated on demand, not
  /// automatically — these three fields are only ever written together.
  aiSummaryRecap       String?
  aiSummaryOpenPoints  String[] @default([])
  aiSummaryGeneratedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  items        Item[]
  receipts     Receipt[]

  @@map("parties")
}

/// Someone who joined a party through the shared link. `editToken` is a
/// second, non-guessable secret handed only to that participant's browser
/// (never rendered for other participants) so they can edit their own entry
/// without an account.
model Participant {
  id        String @id @default(cuid())
  partyId   String
  party     Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  name      String
  editToken String @unique @default(cuid())

  isDriver  Boolean @default(false)
  seatsFree Int?
  needsRide Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributions   Contribution[]
  purchasedItems  Item[]         @relation("PurchasedItems")
  scannedReceipts Receipt[]

  @@index([partyId])
  @@map("participants")
}

/// A shared bucket — either something to buy together (listType
/// SHARED_PURCHASE, with a Food/Drink/Other category) or something people
/// are bringing themselves (BRING_YOUR_OWN, no category, never on the
/// Shopping List). No one "owns" an item; it exists only while it has at
/// least one Contribution, and is deleted once the last one is removed.
model Item {
  id       String        @id @default(cuid())
  partyId  String
  party    Party         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  name     String
  listType ItemListType
  /// Only set (and meaningful) when listType is SHARED_PURCHASE.
  category ItemCategory?

  /// Shopping List purchase lock — only meaningful for SHARED_PURCHASE
  /// items. While purchased, contributions can't be added, edited, or
  /// removed; only purchasedBy (or an admin) can unmark it.
  purchased                Boolean      @default(false)
  purchasedByParticipantId String?
  purchasedBy              Participant? @relation("PurchasedItems", fields: [purchasedByParticipantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  contributions Contribution[]

  @@unique([partyId, listType, name])
  @@index([partyId])
  @@map("items")
}

/// One participant's pledged quantity toward an Item. An item's displayed
/// total is the sum of its contributions; a participant can only edit or
/// remove their own row, never someone else's.
model Contribution {
  id            String      @id @default(cuid())
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  quantity      Int

  @@unique([itemId, participantId])
  @@index([participantId])
  @@map("contributions")
}

/// A single scanned grocery receipt, tied to the party it was bought for
/// (Milestone 1 of Cost Splitting — see PRODUCT.md). Only the AI-extracted
/// structured data (store name, line items) is persisted; the photo itself
/// is used in-memory for the extraction request and never stored. A party
/// can have any number of receipts — one per shopping trip is typical.
model Receipt {
  id                     String       @id @default(cuid())
  partyId                String
  party                  Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)
  /// Whoever scanned the receipt, for context only — not an ownership or
  /// permission boundary; any participant can edit any receipt's line
  /// items, matching this app's open-collaboration model. SetNull (not
  /// Cascade) so the receipt survives that participant later leaving.
  scannedByParticipantId String?
  scannedBy              Participant? @relation(fields: [scannedByParticipantId], references: [id], onDelete: SetNull)
  /// AI-extracted store name, e.g. "REWE" — nullable since extraction may
  /// not find one (faded print, cropped photo).
  store                  String?
  createdAt              DateTime     @default(now())

  lineItems ReceiptLineItem[]

  @@index([partyId])
  @@map("receipts")
}

/// One line item on a Receipt — either AI-extracted from the photo or
/// added/edited by hand afterward, since extraction is expected to be
/// imperfect (glare, faded thermal print, discount lines). `priceCents` is
/// an integer (not Float) to avoid floating-point rounding errors, matching
/// this schema's existing Int quantity fields.
model ReceiptLineItem {
  id         String  @id @default(cuid())
  receiptId  String
  receipt    Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  name       String
  priceCents Int
  quantity   Int     @default(1)
  /// Preserves receipt order (or manual-add order) since line items have no
  /// other natural ordering.
  position   Int

  @@index([receiptId])
  @@map("receipt_line_items")
}
